{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; ./node_modules/.bin/oxfmt \"$f\"; } 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "attribution": {
    "commit": ""
  }
}
